{
  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": {
        "$value": ["Rubik", "system-ui", "sans-serif"],
        "$description": "Body and UI text."
      },
      "display": {
        "$value": ["Red Hat Display", "system-ui", "sans-serif"],
        "$description": "Headings and display."
      },
      "alt": {
        "$value": ["Roboto", "system-ui", "sans-serif"],
        "$description": "Fallback family."
      }
    },
    "weight": {
      "$type": "fontWeight",
      "thin": { "$value": 100 },
      "extralight": { "$value": 200 },
      "light": { "$value": 300 },
      "normal": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 },
      "extrabold": { "$value": 800 }
    },
    "size": {
      "$type": "dimension",
      "xs": { "$value": "0.75rem" },
      "sm": { "$value": "0.875rem" },
      "base": { "$value": "1rem" },
      "lg": { "$value": "1.125rem" },
      "xl": { "$value": "1.25rem" },
      "2xl": { "$value": "1.5rem" },
      "3xl": { "$value": "1.875rem" },
      "4xl": { "$value": "2.25rem" },
      "5xl": { "$value": "3rem" },
      "6xl": { "$value": "3.75rem" }
    }
  },
  "leading": {
    "$type": "number",
    "none": { "$value": 1 },
    "tight": { "$value": 1.1 },
    "snug": { "$value": 1.25 },
    "normal": { "$value": 1.5 },
    "relaxed": { "$value": 1.625 }
  },
  "tracking": {
    "$type": "dimension",
    "tighter": { "$value": "-0.05em" },
    "tight": { "$value": "-0.025em" },
    "normal": { "$value": "0em" },
    "wide": { "$value": "0.025em" },
    "wider": { "$value": "0.05em" }
  }
}
