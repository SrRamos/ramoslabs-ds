{
  "duration": {
    "$type": "duration",
    "fast": { "$value": "150ms" },
    "normal": { "$value": "200ms" },
    "slow": { "$value": "300ms" }
  },
  "easing": {
    "$type": "cubicBezier",
    "linear": { "$value": [0, 0, 1, 1] },
    "in": { "$value": [0.4, 0, 1, 1] },
    "out": { "$value": [0, 0, 0.2, 1] },
    "in-out": { "$value": [0.4, 0, 0.2, 1] },
    "spring": { "$value": [0.34, 1.56, 0.64, 1] }
  }
}
