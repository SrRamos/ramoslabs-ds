{
  "color": {
    "$type": "color",
    "primary": {
      "$value": "{color.indigo.600}",
      "$description": "Brand primary. Indigo 600. Also serves as the single brand accent (no coral)."
    },
    "primary-light": { "$value": "{color.indigo.500}" },
    "primary-dark": { "$value": "{color.indigo.700}" },
    "primary-surface": { "$value": "{color.indigo.50}" },
    "secondary": { "$value": "{color.violet.500}" },
    "secondary-light": { "$value": "{color.violet.400}" },
    "secondary-dark": { "$value": "{color.violet.600}" },
    "secondary-surface": { "$value": "{color.violet.50}" },
    "success": { "$value": "{color.emerald.500}" },
    "success-strong": {
      "$value": "{color.emerald.600}",
      "$description": "AA-safe green fill for a white glyph on the success color (emerald 500 is only 2.54:1 with white, below the 3:1 non-text floor)."
    },
    "success-surface": { "$value": "{color.green.50}" },
    "success-border": { "$value": "{color.green.200}" },
    "success-text": { "$value": "{color.green.800}" },
    "warning": { "$value": "{color.amber.500}" },
    "warning-surface": { "$value": "{color.amber.50}" },
    "warning-border": { "$value": "{color.amber.200}" },
    "warning-text": { "$value": "{color.amber.900}" },
    "error": { "$value": "{color.red.500}" },
    "error-strong": {
      "$value": "{color.red.600}",
      "$description": "AA-safe red fill for white text on buttons (red 500 is only 3.76:1 on white)."
    },
    "error-surface": { "$value": "{color.red.50}" },
    "error-border": { "$value": "{color.red.200}" },
    "error-text": { "$value": "{color.red.800}" },
    "info": { "$value": "{color.blue.500}" },
    "info-surface": { "$value": "{color.blue.50}" },
    "info-border": { "$value": "{color.blue.200}" },
    "info-text": { "$value": "{color.blue.800}" },
    "text-heading": { "$value": "{color.slate.900}" },
    "text-strong": { "$value": "{color.slate.800}" },
    "text-secondary": { "$value": "{color.slate.600}" },
    "text-body": { "$value": "{color.slate.500}" },
    "text-muted": { "$value": "{color.slate.500}" },
    "text-disabled": { "$value": "{color.slate.300}" },
    "surface": { "$value": "{color.white}" },
    "surface-secondary": { "$value": "{color.slate.50}" },
    "surface-hover": { "$value": "{color.slate.100}" },
    "background": { "$value": "{color.slate.50}" },
    "border": { "$value": "#e6e8eb" },
    "border-light": { "$value": "{color.slate.200}" },
    "border-subtle": { "$value": "{color.slate.100}" },
    "focus": { "$value": "{color.indigo.600}" }
  }
}
