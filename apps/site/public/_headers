# Cloudflare Pages headers for the RamosLabs DS site.
# The agent-facing files are served from the site root with the right Content-Type
# and permissive CORS so AI agents can fetch them cross-origin.

/llms.txt
  Content-Type: text/plain; charset=utf-8
  Access-Control-Allow-Origin: *

/llms-full.txt
  Content-Type: text/plain; charset=utf-8
  Access-Control-Allow-Origin: *

/registry.json
  Content-Type: application/json; charset=utf-8
  Access-Control-Allow-Origin: *

/tokens.json
  Content-Type: application/json; charset=utf-8
  Access-Control-Allow-Origin: *

/AGENTS.md
  Content-Type: text/markdown; charset=utf-8
  Access-Control-Allow-Origin: *

/skill.md
  Content-Type: text/markdown; charset=utf-8
  Access-Control-Allow-Origin: *

# Self-hosted fonts: immutable, long-lived cache.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *
