---
// Unlisted internal usage dashboard. NOT part of the DS docs: no sidebar, no nav entry,
// noindex, excluded from the sitemap, and never linked from llms.txt or robots.txt.
// Reads the unlisted /metricas.json feed (npm downloads + Analytics Engine aggregates).
import '../styles/global.css'
import Icon from '../components/Icon.astro'
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <title>Usage — RamosLabs DS (internal)</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preload" href="/fonts/red-hat-display-var.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/rubik-var.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <main class="mx">
      <header class="mx-top">
        <div class="mx-brand">
          <span class="mx-brand-mark" aria-hidden="true"></span>
          <div>
            <div class="mx-brand-title">RamosLabs DS</div>
            <div class="mx-brand-sub">Usage · internal</div>
          </div>
        </div>
        <div class="mx-top-actions">
          <span class="mx-chip"><Icon name="lock" style="font-size:14px" />Unlisted</span>
          <button type="button" class="mx-refresh" id="mx-refresh"><Icon name="refresh" style="font-size:16px" />Refresh</button>
        </div>
      </header>

      <h1 class="mx-h1">Adoption, in one place.</h1>
      <p class="mx-lead">npm downloads, page views, agent-file fetches, and MCP tool calls. Cookieless, no PII. Read live from <code>/metricas.json</code>.</p>

      <!-- npm -->
      <section class="mx-section">
        <div class="mx-label">npm downloads · <code>@ramoslabs/tokens</code></div>
        <div class="mx-stats">
          <div class="mx-stat"><div class="mx-stat-value" id="npm-month">—</div><div class="mx-stat-label">Last 30 days</div></div>
          <div class="mx-stat"><div class="mx-stat-value" id="npm-week">—</div><div class="mx-stat-label">Last 7 days</div></div>
          <div class="mx-stat"><div class="mx-stat-value" id="npm-day">—</div><div class="mx-stat-label">Last day</div></div>
        </div>
      </section>

      <!-- Daily trend — bespoke SVG line/area with grid, axes, and hover tooltip
           (charts house pattern), RamosLabs tokens only. Labels are HTML overlays
           because the SVG uses preserveAspectRatio="none" (SVG text would distort). -->
      <section class="mx-section" id="mx-trend-wrap" hidden>
        <div class="mx-label">npm downloads · daily trend · last 30 days</div>
        <div class="mx-panel">
          <div class="mx-chart">
            <div class="mx-yaxis" id="mx-yaxis" aria-hidden="true"></div>
            <div class="mx-plot" id="mx-plot" role="img" aria-label="npm downloads daily trend, last 30 days">
              <svg class="mx-chart-svg" viewBox="0 0 1000 280" preserveAspectRatio="none" aria-hidden="true">
                <defs>
                  <linearGradient id="mx-area-grad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" class="mx-area-top" />
                    <stop offset="100%" class="mx-area-bottom" />
                  </linearGradient>
                </defs>
                <g class="mx-grid" id="mx-grid"></g>
                <path class="mx-chart-area" id="mx-area" d="" fill="url(#mx-area-grad)" />
                <path class="mx-chart-line" id="mx-line" d="" fill="none" pathLength="100" vector-effect="non-scaling-stroke" />
                <line class="mx-cross" id="mx-cross" x1="0" y1="20" x2="0" y2="250" vector-effect="non-scaling-stroke" hidden />
              </svg>
              <span class="mx-dot" id="mx-dot" hidden></span>
              <div class="mx-tip" id="mx-tip" role="presentation" hidden></div>
            </div>
            <div class="mx-xaxis" id="mx-xaxis" aria-hidden="true"></div>
            <table class="mx-sr" id="mx-trend-table">
              <caption>npm downloads per day, last 30 days</caption>
              <thead><tr><th scope="col">Day</th><th scope="col">Downloads</th></tr></thead>
              <tbody></tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- server-side usage -->
      <section class="mx-section">
        <div class="mx-label">Server-side · last 30 days</div>

        <div class="mx-note" id="mx-loading"><Icon name="sync" /><p>Loading from <code>/metricas.json</code>…</p></div>
        <div class="mx-note warn" id="mx-error" hidden><Icon name="error" /><p><code>/metricas.json</code> is served by the Worker — reachable after deploy, or via <code>bunx wrangler dev</code>.</p></div>

        <div class="mx-setup" id="mx-setup" hidden>
          <div class="mx-setup-icon"><Icon name="build" /></div>
          <div>
            <h3 class="mx-setup-title">One token from live usage</h3>
            <p class="mx-setup-text">npm downloads show above. To light up page / agent-file / MCP metrics, give the Worker read access to Analytics Engine:</p>
            <pre class="mx-pre"><span class="cm"># CF_ACCOUNT_ID as a var + a read-only secret token</span>
bunx wrangler secret put CF_ANALYTICS_TOKEN</pre>
            <p class="mx-setup-text">Full setup in <code>docs/ANALYTICS.md</code>.</p>
          </div>
        </div>

        <div id="mx-data" hidden>
          <div class="mx-stats">
            <div class="mx-stat alt"><div class="mx-stat-value" id="u-page">—</div><div class="mx-stat-label">Page views</div></div>
            <div class="mx-stat alt"><div class="mx-stat-value" id="u-mcp">—</div><div class="mx-stat-label">MCP tool calls</div></div>
            <div class="mx-stat alt"><div class="mx-stat-value" id="u-file">—</div><div class="mx-stat-label">Agent-file fetches</div></div>
          </div>
          <div class="mx-cols">
            <div class="mx-panel"><h3 class="mx-panel-title"><Icon name="hub" />MCP by tool</h3><div class="mx-bars" id="u-tools"></div></div>
            <div class="mx-panel"><h3 class="mx-panel-title"><Icon name="description" />Agent files</h3><div class="mx-bars" id="u-files"></div></div>
          </div>
          <div class="mx-panel"><h3 class="mx-panel-title"><Icon name="menu_book" />Top pages</h3><div class="mx-bars" id="u-pages"></div></div>
        </div>
      </section>

      <footer class="mx-foot">
        <Icon name="lock" />
        <p>Cookieless, no PII, no fingerprinting. npm counts are public; page/agent/MCP metrics are aggregate request data from Cloudflare Analytics Engine. This page is unlisted and noindex.</p>
      </footer>
    </main>

    <script>
      const fmt = (n) => (typeof n === 'number' && isFinite(n) ? n.toLocaleString('en-US') : '—')
      const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = fmt(v) }
      const show = (id) => { const el = document.getElementById(id); if (el) el.hidden = false }
      const hide = (id) => { const el = document.getElementById(id); if (el) el.hidden = true }
      const num = (v) => { const n = Number(v); return isFinite(n) ? n : 0 }

      function bars(containerId, rows, empty) {
        const box = document.getElementById(containerId)
        if (!box) return
        box.textContent = ''
        if (!rows || !rows.length) {
          const p = document.createElement('p'); p.className = 'mx-empty'; p.textContent = empty || 'No data yet.'; box.appendChild(p); return
        }
        const max = Math.max(...rows.map((r) => r.value), 1)
        for (const r of rows) {
          const row = document.createElement('div'); row.className = 'mx-bar'
          const label = document.createElement('span'); label.className = 'mx-bar-label'; label.textContent = r.label
          const track = document.createElement('span'); track.className = 'mx-bar-track'
          const fill = document.createElement('span'); fill.className = 'mx-bar-fill'; fill.style.width = Math.max(2, Math.round((r.value / max) * 100)) + '%'
          track.appendChild(fill)
          const val = document.createElement('span'); val.className = 'mx-bar-value'; val.textContent = fmt(r.value)
          row.append(label, track, val); box.appendChild(row)
        }
      }

      // Catmull-Rom → cubic-bezier smoothing (the charts house pattern's geometry, inlined).
      function smooth(p) {
        if (p.length < 3) return 'M ' + p.map((q) => `${q.x},${q.y}`).join(' L ')
        const clamp = (v, lo, hi) => Math.max(lo, Math.min(hi, v))
        let d = `M ${p[0].x},${p[0].y}`
        for (let i = 0; i < p.length - 1; i++) {
          const p0 = p[i - 1] || p[i], p1 = p[i], p2 = p[i + 1], p3 = p[i + 2] || p2
          // Keep control points inside each segment's vertical band → monotone, no over/undershoot.
          const loY = Math.min(p1.y, p2.y), hiY = Math.max(p1.y, p2.y)
          const c1x = p1.x + (p2.x - p0.x) / 6, c1y = clamp(p1.y + (p2.y - p0.y) / 6, loY, hiY)
          const c2x = p2.x - (p3.x - p1.x) / 6, c2y = clamp(p2.y - (p3.y - p1.y) / 6, loY, hiY)
          d += ` C ${c1x},${c1y} ${c2x},${c2y} ${p2.x},${p2.y}`
        }
        return d
      }

      const GEO = { W: 1000, H: 280, baseline: 250, padTop: 20 }
      const SVGNS = 'http://www.w3.org/2000/svg'
      const xPct = (xvb) => (xvb / GEO.W) * 100
      const yPct = (yvb) => (yvb / GEO.H) * 100
      const yFor = (v, max) => GEO.baseline - (v / max) * (GEO.baseline - GEO.padTop)
      const mmdd = (day) => { const p = String(day).split('-'); return p.length === 3 ? `${p[1]}/${p[2]}` : day }
      let chart = null // { co, pts, max } for hover

      function trend(series) {
        const wrap = document.getElementById('mx-trend-wrap')
        const line = document.getElementById('mx-line')
        const area = document.getElementById('mx-area')
        const plot = document.getElementById('mx-plot')
        const grid = document.getElementById('mx-grid')
        const yax = document.getElementById('mx-yaxis')
        const xax = document.getElementById('mx-xaxis')
        const tbody = document.querySelector('#mx-trend-table tbody')
        if (!wrap || !line || !area) return
        const pts = series.map((d) => ({ day: d.day, v: num(d.downloads) }))
        if (pts.length < 2) { wrap.hidden = true; return }
        const n = pts.length
        const max = Math.max(...pts.map((p) => p.v), 1)
        const co = pts.map((p, i) => ({ x: (i / (n - 1)) * GEO.W, y: yFor(p.v, max), day: p.day, v: p.v }))
        chart = { co, pts, max }

        const lp = smooth(co)
        line.setAttribute('d', lp)
        area.setAttribute('d', `${lp} L ${co[n - 1].x},${GEO.baseline} L ${co[0].x},${GEO.baseline} Z`)

        // Y grid + labels at 0 / half / max.
        const ticks = [0, Math.round(max / 2), max].filter((t, i, a) => a.indexOf(t) === i)
        grid.textContent = ''; yax.textContent = ''
        for (const t of ticks) {
          const yv = yFor(t, max)
          const gl = document.createElementNS(SVGNS, 'line')
          gl.setAttribute('x1', '0'); gl.setAttribute('x2', String(GEO.W))
          gl.setAttribute('y1', String(yv)); gl.setAttribute('y2', String(yv))
          gl.setAttribute('vector-effect', 'non-scaling-stroke')
          grid.appendChild(gl)
          const lab = document.createElement('span')
          lab.className = 'mx-yaxis-lab'; lab.textContent = fmt(t)
          lab.style.top = yPct(yv) + '%'
          yax.appendChild(lab)
        }

        // X labels: first / middle / last date.
        xax.textContent = ''
        const idxs = [...new Set([0, Math.floor((n - 1) / 2), n - 1])]
        for (const i of idxs) {
          const lab = document.createElement('span')
          lab.className = 'mx-xaxis-lab'; lab.textContent = mmdd(co[i].day)
          lab.style.left = xPct(co[i].x) + '%'
          if (i === 0) lab.style.transform = 'translateX(0)'
          else if (i === n - 1) lab.style.transform = 'translateX(-100%)'
          else lab.style.transform = 'translateX(-50%)'
          xax.appendChild(lab)
        }

        const total = pts.reduce((s, p) => s + p.v, 0)
        const peak = pts.reduce((m, p) => (p.v > m.v ? p : m), pts[0])
        if (plot) plot.setAttribute('aria-label', `npm downloads daily, last 30 days: ${fmt(total)} total, peak ${fmt(peak.v)} on ${peak.day}.`)
        if (tbody) {
          tbody.textContent = ''
          for (const p of pts) {
            const tr = document.createElement('tr')
            const td1 = document.createElement('td'); td1.textContent = p.day
            const td2 = document.createElement('td'); td2.textContent = String(p.v)
            tr.append(td1, td2); tbody.appendChild(tr)
          }
        }
        wrap.hidden = false
      }

      // Hover: crosshair + dot + tooltip. The tooltip is decorative (data lives in the table),
      // so it carries no aria-live. getBoundingClientRect is cached out of pointermove.
      ;(function setupHover() {
        const plot = document.getElementById('mx-plot')
        const cross = document.getElementById('mx-cross')
        const dot = document.getElementById('mx-dot')
        const tip = document.getElementById('mx-tip')
        if (!plot || !cross || !dot || !tip) return
        let rect = null
        const capture = () => { rect = plot.getBoundingClientRect() }
        const move = (e) => {
          if (!chart) return
          const r = rect || plot.getBoundingClientRect()
          if (!r || r.width === 0) return
          const ratio = (e.clientX - r.left) / r.width
          const n = chart.co.length
          const i = Math.min(n - 1, Math.max(0, Math.round(ratio * (n - 1))))
          const c = chart.co[i]
          cross.setAttribute('x1', String(c.x)); cross.setAttribute('x2', String(c.x)); cross.removeAttribute('hidden')
          dot.style.left = xPct(c.x) + '%'; dot.style.top = yPct(c.y) + '%'; dot.hidden = false
          tip.textContent = ''
          const d = document.createElement('span'); d.className = 'mx-tip-day'; d.textContent = mmdd(c.day)
          const v = document.createElement('span'); v.className = 'mx-tip-val'; v.textContent = `${fmt(c.v)} downloads`
          tip.append(d, v)
          tip.style.left = Math.max(8, Math.min(92, xPct(c.x))) + '%'
          tip.style.top = yPct(c.y) + '%'
          tip.hidden = false
        }
        const leave = () => { cross.setAttribute('hidden', ''); dot.hidden = true; tip.hidden = true; rect = null }
        plot.addEventListener('pointerenter', capture)
        plot.addEventListener('pointerdown', capture)
        plot.addEventListener('pointermove', move)
        plot.addEventListener('pointerleave', leave)
      })()

      function load() {
        hide('mx-error'); hide('mx-setup'); hide('mx-data'); show('mx-loading'); hide('mx-trend-wrap')
        fetch('/metricas.json', { headers: { accept: 'application/json' }, cache: 'no-store' })
          .then((r) => { if (!r.ok) throw new Error(String(r.status)); return r.json() })
          .then((d) => {
            hide('mx-loading')
            const dl = (d.npm && d.npm.downloads) || {}
            set('npm-month', dl['last-month']); set('npm-week', dl['last-week']); set('npm-day', dl['last-day'])
            trend((d.npm && d.npm.series) || [])
            const u = d.usage
            if (!u) { show('mx-setup'); return }
            const byType = {}
            for (const row of u.byType || []) byType[row.type] = num(row.n)
            set('u-page', byType.page || 0); set('u-mcp', byType.mcp || 0); set('u-file', byType.agent_file || 0)
            bars('u-tools', (u.mcpByTool || []).map((r) => ({ label: r.detail, value: num(r.n) })), 'No MCP calls yet.')
            bars('u-files', (u.agentFiles || []).map((r) => ({ label: r.file, value: num(r.n) })), 'No agent-file fetches yet.')
            bars('u-pages', (u.topPages || []).map((r) => ({ label: r.path, value: num(r.n) })), 'No page views yet.')
            show('mx-data')
          })
          .catch(() => { hide('mx-loading'); show('mx-error') })
      }
      document.getElementById('mx-refresh')?.addEventListener('click', load)
      load()
    </script>

    <style is:global>
      /* The [hidden] attribute must win over the flex/grid display rules below. */
      [hidden] { display: none !important; }
      body { background: var(--color-surface-secondary); }
      .mx { max-width: 1000px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; }

      .mx-top { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 2.5rem; flex-wrap: wrap; }
      .mx-brand { display: flex; align-items: center; gap: 0.75rem; }
      .mx-brand-mark { width: 34px; height: 34px; border-radius: var(--radius-md); background: linear-gradient(135deg, var(--color-primary), var(--color-secondary)); box-shadow: var(--shadow-sm); }
      .mx-brand-title { font-family: var(--font-family-display); font-weight: 800; font-size: 1.05rem; color: var(--color-text-heading); line-height: 1; }
      .mx-brand-sub { font-family: var(--font-family-sans); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-muted); margin-top: 3px; }
      .mx-top-actions { display: flex; align-items: center; gap: 0.6rem; }
      .mx-chip { display: inline-flex; align-items: center; gap: 0.35rem; font-family: var(--font-family-sans); font-size: 0.72rem; font-weight: 600; color: var(--color-secondary-dark); background: var(--color-secondary-surface); padding: 0.3rem 0.65rem; border-radius: var(--radius-pill); }
      .mx-chip .material-symbols-outlined { color: var(--color-secondary); }
      .mx-refresh { display: inline-flex; align-items: center; gap: 0.4rem; font-family: var(--font-family-sans); font-weight: 600; font-size: 0.85rem; color: var(--color-primary-dark); background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 0.45rem 0.8rem; cursor: pointer; }
      .mx-refresh:hover { background: var(--color-surface-hover); }
      .mx-refresh:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 2px; }

      .mx-h1 { font-family: var(--font-family-display); font-size: clamp(1.9rem, 4vw, 2.6rem); font-weight: 900; letter-spacing: -0.02em; color: var(--color-text-heading); margin: 0 0 0.5rem 0; }
      .mx-lead { font-family: var(--font-family-sans); font-size: 1rem; color: var(--color-text-muted); line-height: 1.6; max-width: 46rem; margin: 0 0 2.5rem 0; }
      .mx-lead code, .mx-label code { font-family: 'SF Mono','Monaco',monospace; font-size: 0.88em; color: var(--color-primary-dark); }

      .mx-section { margin-bottom: 2.5rem; }
      .mx-label { font-family: var(--font-family-sans); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; color: var(--color-primary); letter-spacing: 0.12em; margin-bottom: 1rem; }

      .mx-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1rem; }
      @media (max-width: 640px) { .mx-stats { grid-template-columns: 1fr; } }
      .mx-stat { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.75rem 1rem; text-align: center; box-shadow: var(--shadow-sm); }
      .mx-stat-value { font-family: var(--font-family-display); font-size: 2.75rem; font-weight: 900; line-height: 1; background: linear-gradient(135deg, var(--color-primary), var(--color-secondary)); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 0.4rem; }
      .mx-stat.alt .mx-stat-value { background: none; -webkit-text-fill-color: initial; color: var(--color-text-heading); }
      .mx-stat-label { font-family: var(--font-family-sans); font-size: 0.82rem; color: var(--color-text-muted); font-weight: 500; }

      /* Visually-hidden table (the accessible data path for the SVG chart). */
      .mx-sr { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }
      .mx-chart { display: grid; grid-template-columns: 46px 1fr; grid-template-rows: 220px 20px; column-gap: 8px; }
      .mx-yaxis { grid-column: 1; grid-row: 1; position: relative; }
      .mx-yaxis-lab { position: absolute; right: 0; transform: translateY(-50%); font-family: var(--font-family-sans); font-size: 0.68rem; color: var(--color-text-muted); font-variant-numeric: tabular-nums; white-space: nowrap; }
      .mx-plot { grid-column: 2; grid-row: 1; position: relative; touch-action: none; }
      .mx-xaxis { grid-column: 2; grid-row: 2; position: relative; }
      .mx-xaxis-lab { position: absolute; top: 4px; font-family: var(--font-family-sans); font-size: 0.68rem; color: var(--color-text-muted); font-variant-numeric: tabular-nums; white-space: nowrap; }
      .mx-chart-svg { width: 100%; height: 100%; display: block; overflow: visible; }
      .mx-grid line { stroke: var(--color-border-subtle); stroke-width: 1; stroke-dasharray: 3 4; }
      .mx-cross { stroke: var(--color-primary); stroke-width: 1; stroke-dasharray: 3 3; opacity: 0.55; }
      .mx-dot { position: absolute; width: 11px; height: 11px; border-radius: var(--radius-pill); background: var(--color-primary); border: 2px solid var(--color-surface); transform: translate(-50%, -50%); box-shadow: var(--shadow-sm); pointer-events: none; z-index: 1; }
      .mx-tip { position: absolute; transform: translate(-50%, calc(-100% - 14px)); background: var(--color-text-heading); border-radius: var(--radius-md); padding: 0.4rem 0.65rem; display: flex; flex-direction: column; gap: 0.05rem; pointer-events: none; white-space: nowrap; box-shadow: var(--shadow-md); z-index: 2; }
      .mx-tip-day { font-family: var(--font-family-sans); font-size: 0.66rem; color: var(--color-primary-surface); }
      .mx-tip-val { font-family: var(--font-family-sans); font-size: 0.82rem; font-weight: 600; color: var(--color-surface); font-variant-numeric: tabular-nums; }
      .mx-area-top { stop-color: var(--color-primary); stop-opacity: 0.2; }
      .mx-area-bottom { stop-color: var(--color-primary); stop-opacity: 0; }
      .mx-chart-line {
        stroke: var(--color-primary); stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;
        stroke-dasharray: 100; stroke-dashoffset: 0;
        animation: mx-draw var(--duration-slow, 1s) var(--easing-out, ease);
      }
      @keyframes mx-draw { from { stroke-dashoffset: 100; } to { stroke-dashoffset: 0; } }
      @media (prefers-reduced-motion: reduce) { .mx-chart-line { animation: none; } }

      .mx-note { display: flex; gap: 0.75rem; align-items: center; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1rem 1.25rem; max-width: 46rem; }
      .mx-note .material-symbols-outlined { color: var(--color-primary); flex-shrink: 0; }
      .mx-note p { font-family: var(--font-family-sans); font-size: 0.9rem; color: var(--color-text-secondary); margin: 0; line-height: 1.55; }
      .mx-note code { font-family: 'SF Mono','Monaco',monospace; font-size: 0.85em; color: var(--color-primary-dark); }
      .mx-note.warn { background: var(--color-warning-surface); border-color: var(--color-warning-border); }
      .mx-note.warn .material-symbols-outlined, .mx-note.warn p { color: var(--color-warning-text); }

