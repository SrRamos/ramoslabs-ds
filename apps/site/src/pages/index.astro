---
import BaseLayout from '../layouts/BaseLayout.astro'
import Icon from '../components/Icon.astro'
import { pages, foundationsPages, patternsPages } from '../data/pages'
const page = pages.find((p) => p.id === 'introduction')!

// Short book-map taglines by page id. The grids below are generated from pages.ts,
// so adding a page there automatically shows it here (no more drift).
const BLURBS: Record<string, string> = {
  colors: 'Mono-indigo palette',
  typography: 'Scale and families',
  spacing: '8px base grid',
  'border-radius': 'Corner scale',
  shadows: 'Elevation scale',
  motion: 'Duration, easing',
  responsive: 'Breakpoints',
  helpers: 'Utility classes',
  'token-reference': 'Every token, copyable',
  'color-picker': 'Contrast explorer',
  interactive: 'States, feedback',
  accessibility: 'WCAG guidance',
  'form-elements': 'Inputs, validation',
  'data-tables': 'Sorting, selection',
  modals: 'Native dialog',
  'mobile-first': 'Small-screen first',
  persuasion: 'Honest nudges',
  'voice-tone': 'Copy, microcopy',
  'ai-insights': 'Generated content',
}
---
<BaseLayout title={page.title} description={page.summary} path={page.path}>

<!-- ===== HERO ===== -->
<div class="intro-hero">
  <div class="intro-hero-version">v0.1</div>
  <div class="intro-hero-inner">
    <div class="intro-hero-badge">
      <Icon name="menu_book" style="font-size:15px" />
      The RamosLabs Design System
    </div>
    <h1 class="intro-hero-title">Most systems ship components. <em>This one ships the decisions.</em></h1>
    <p class="intro-hero-subtitle">A taxonomy book: one indigo, one token contract, and the rules that turn them into a UI library you own, not a bundle you import.</p>
  </div>
</div>

<!-- ===== STATS ===== -->
<div class="intro-lead">The whole system, in four numbers</div>
<div class="intro-stats">
  <div class="intro-stat">
    <div class="intro-stat-value">213</div>
    <div class="intro-stat-label">Design tokens</div>
  </div>
  <div class="intro-stat">
    <div class="intro-stat-value">3</div>
    <div class="intro-stat-label">Taxonomy tiers</div>
  </div>
  <div class="intro-stat">
    <div class="intro-stat-value">AA</div>
    <div class="intro-stat-label">Contrast floor</div>
  </div>
  <div class="intro-stat">
    <div class="intro-stat-value">1</div>
    <div class="intro-stat-label">Action accent</div>
  </div>
</div>

<!-- ===== TAXONOMY FLOW ===== -->
<div class="intro-section">
  <div class="intro-head">
    <div class="intro-head-label">The taxonomy</div>
    <h2 class="intro-head-title">Three tiers, one direction</h2>
  </div>

  <div class="flow">
    <div class="flow-node t1">
      <span class="flow-tier">Tier 1</span>
      <h3 class="flow-name">Foundations</h3>
      <p class="flow-desc">The token contract. Color, type, space, radius, shadow, motion. Start here.</p>
      <div class="flow-meta">references: primitives</div>
    </div>
    <div class="flow-arrow"><Icon name="arrow_forward" /></div>
    <div class="flow-node t2">
      <span class="flow-tier">Tier 2</span>
      <h3 class="flow-name">Patterns</h3>
      <p class="flow-desc">Recipes built from foundations: states, forms, accessibility, voice.</p>
      <div class="flow-meta">references: foundations</div>
    </div>
    <div class="flow-arrow"><Icon name="arrow_forward" /></div>
    <div class="flow-node t3">
      <span class="flow-tier">Tier 3</span>
      <h3 class="flow-name">Components</h3>
      <p class="flow-desc">SJ and W UI, built only from patterns and foundations. Coming next.</p>
      <div class="flow-meta">references: patterns, foundations</div>
    </div>
  </div>

  <div class="flow-rule">
    <strong>The one rule:</strong> a tier may reference the tier below, never above. That single constraint is what keeps the system coherent as it grows.
  </div>
</div>

<!-- ===== NAMING ===== -->
<div class="intro-section">
  <div class="intro-head">
    <div class="intro-head-label">Naming</div>
    <h2 class="intro-head-title">The name tells you where it lives</h2>
  </div>

  <div class="name-grid">
    <div class="name-card">
      <span class="name-tag">SJ</span>
      <h3 class="name-scope">Shared, domain-free UI</h3>
      <p class="name-desc"><code>SJButton</code>, <code>SJInput</code>. Built only from tokens and patterns. No business logic.</p>
    </div>
    <div class="name-card">
      <span class="name-tag">W</span>
      <h3 class="name-scope">App-specific widget</h3>
      <p class="name-desc"><code>WEventCard</code>, <code>WCheckoutSummary</code>. Composes SJ components; holds the domain logic.</p>
    </div>
    <div class="name-card">
      <span class="name-tag">--token</span>
      <h3 class="name-scope">The value contract</h3>
      <p class="name-desc"><code>var(--color-primary)</code>, <code>var(--space-6)</code>. The only source of color, space, and type. Never a raw hex.</p>
    </div>
  </div>
</div>

<!-- ===== SINGLE SOURCE ===== -->
<div class="intro-section">
  <div class="intro-head">
    <div class="intro-head-label">Single source of truth</div>
    <h2 class="intro-head-title">Authored once, compiled everywhere</h2>
  </div>

  <div class="pipe-grid">
    <div>
      <div class="pipe">
        <div class="pipe-node">
          <Icon name="data_object" />
          <div class="pipe-node-label">tokens.json<br/>DTCG</div>
        </div>
        <div class="pipe-arrow"><Icon name="arrow_forward" /></div>
        <div class="pipe-node">
          <Icon name="bolt" />
          <div class="pipe-node-label">Style<br/>Dictionary</div>
        </div>
        <div class="pipe-arrow"><Icon name="arrow_forward" /></div>
        <div class="pipe-node">
          <Icon name="css" />
          <div class="pipe-node-label">CSS vars<br/>+ TypeScript</div>
        </div>
      </div>
      <p class="pipe-line"><strong>Change a token once</strong>, and every surface that references it updates in step. The DTCG JSON is the contract; nothing downstream is edited by hand.</p>
    </div>
    <div class="intro-code">
      <div class="intro-code-header">
        <span class="intro-code-dot d1"></span>
        <span class="intro-code-dot d2"></span>
        <span class="intro-code-dot d3"></span>
        <span class="intro-code-lang">TS / CSS</span>
      </div>
      <pre set:html={`<span class="c-cm">// app entry, once</span>
<span class="c-kw">import</span> <span class="c-val">'@ramoslabs/tokens/css'</span><span class="c-p">;</span>

<span class="c-cm">/* then build against the contract */</span>
<span class="c-sel">.sj-card</span> <span class="c-p">{</span>
    <span class="c-prop">background</span><span class="c-p">:</span> <span class="c-val">var(--color-surface)</span><span class="c-p">;</span>
    <span class="c-prop">padding</span><span class="c-p">:</span> <span class="c-val">var(--space-6)</span><span class="c-p">;</span>
    <span class="c-prop">border-radius</span><span class="c-p">:</span> <span class="c-val">var(--radius-lg)</span><span class="c-p">;</span>
    <span class="c-prop">box-shadow</span><span class="c-p">:</span> <span class="c-val">var(--shadow-sm)</span><span class="c-p">;</span>
<span class="c-p">}</span>`}></pre>
    </div>
  </div>
</div>

<!-- ===== BOOK MAP ===== -->
<div class="intro-section">
  <div class="intro-head">
    <div class="intro-head-label">Navigate the book</div>
    <h2 class="intro-head-title">Where to go next</h2>
  </div>

  <div class="book-group">
    <div class="book-group-head">
      <span class="book-group-tier">Tier 1</span>
      <span class="book-group-name">Foundations</span>
      <span class="book-group-count">The token contract</span>
    </div>
    <div class="book-grid">
      {foundationsPages.map((p) => (
        <a class="book-card" href={p.path}>
          <div class="book-card-icon f1"><Icon name={p.icon} /></div>
          <div class="book-card-title">{p.title}</div>
          <div class="book-card-desc">{BLURBS[p.id] ?? ''}</div>
        </a>
      ))}
    </div>
  </div>

  <div class="book-group">
    <div class="book-group-head">
      <span class="book-group-tier">Tier 2</span>
      <span class="book-group-name">Patterns</span>
      <span class="book-group-count">Behavior from tokens</span>
    </div>
    <div class="book-grid">
      {patternsPages.map((p) => (
        <a class="book-card" href={p.path}>
          <div class="book-card-icon f2"><Icon name={p.icon} /></div>
          <div class="book-card-title">{p.title}</div>
          <div class="book-card-desc">{BLURBS[p.id] ?? ''}</div>
        </a>
      ))}
    </div>
  </div>

  <div class="book-group">
    <div class="book-group-head">
      <span class="book-group-tier">Tier 3</span>
      <span class="book-group-name">Components</span>
      <span class="book-group-count">Coming next</span>
    </div>
    <div class="book-grid">
      <div class="book-card soon">
        <div class="book-card-icon f3"><Icon name="widgets" /></div>
        <div class="book-card-title">SJ Component Library</div>
        <div class="book-card-desc">Reusable, domain-free UI</div>
        <span class="book-card-soon">Soon</span>
      </div>
      <div class="book-card soon">
        <div class="book-card-icon f3"><Icon name="dashboard_customize" /></div>
        <div class="book-card-title">W Domain Widgets</div>
        <div class="book-card-desc">App-specific compositions</div>
        <span class="book-card-soon">Soon</span>
      </div>
    </div>
  </div>
</div>

<!-- ===== FOOTER ===== -->
<div class="intro-footer">
  <div class="intro-footer-text">Built so the tokens do the work.</div>
  <div class="intro-footer-sources">
    Built on the <a href="https://www.designtokens.org/TR/drafts/format/" target="_blank" rel="noreferrer">W3C Design Tokens</a> spec, <a href="https://atomicdesign.bradfrost.com/chapter-2/" target="_blank" rel="noreferrer">Atomic Design</a>, and <a href="https://www.w3.org/TR/WCAG21/" target="_blank" rel="noreferrer">WCAG 2.1</a>.
  </div>
</div>

<style is:global>
  /* ===== HERO ===== */
  .intro-hero {
    background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 45%, var(--color-secondary) 100%);
    margin: -1rem -1rem 4rem -1rem;
    padding: 5rem 3rem;
    border-radius: 0 0 var(--radius-xl) var(--radius-xl);
    position: relative;
    overflow: hidden;
  }

  .intro-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    opacity: 0.5;
  }

  .intro-hero-inner { position: relative; z-index: 1; }

  .intro-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    color: white;
    font-family: var(--font-family-sans);
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.4rem 0.9rem;
    border-radius: 6px;
    margin-bottom: 1.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .intro-hero-title {
    font-family: var(--font-family-display);
    color: white;
    font-size: clamp(2.75rem, 6.5vw, 4.5rem);
    font-weight: 900;
    line-height: 1.02;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem 0;
    max-width: 900px;
  }

  .intro-hero-title em {
    font-style: normal;
    color: #e0e7ff;
  }

  .intro-hero-subtitle {
    font-family: var(--font-family-sans);
    color: rgba(255, 255, 255, 0.92);
    font-size: 1.3rem;
    font-weight: 300;
    line-height: 1.55;
    max-width: 640px;
    margin: 0;
  }

  .intro-hero-version {
    position: absolute;
    top: 1.75rem;
    right: 1.75rem;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(10px);
    color: white;
    font-family: var(--font-family-sans);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.35rem 0.9rem;
    border-radius: 6px;
    z-index: 1;
  }

  /* ===== STATS ===== */
  .intro-lead {
    text-align: center;
    font-family: var(--font-family-sans);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
  }

  .intro-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 5rem;
  }

  @media (max-width: 700px) {
    .intro-stats { grid-template-columns: repeat(2, 1fr); }
  }

  .intro-stat {
    background: var(--color-surface);
    padding: 1.75rem 1rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    text-align: center;
    box-shadow: var(--shadow-sm);
  }

  .intro-stat-value {
    font-family: var(--font-family-display);
    font-size: 3rem;
    font-weight: 900;
    line-height: 1;
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 0.4rem;
  }

  .intro-stat-label {
    font-family: var(--font-family-sans);
    font-size: 0.82rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  /* ===== SECTION SCAFFOLD ===== */
  .intro-section { margin-bottom: 5rem; }

  .intro-head { margin-bottom: 2rem; }
  .intro-head.center { text-align: center; }

  .intro-head-label {
    font-family: var(--font-family-sans);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-primary);
    letter-spacing: 0.15em;
    margin-bottom: 0.6rem;
  }

  .intro-head-title {
    font-family: var(--font-family-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.015em;
    color: var(--color-text-heading);
    margin: 0;
    line-height: 1.1;
  }

  /* ===== TIER FLOW ===== */
  .flow {
    display: flex;
    align-items: stretch;
    gap: 0;
    flex-wrap: nowrap;
  }

  .flow-node {
    flex: 1;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .flow-node::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
  }

  .flow-node.t1::before { background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light)); }
  .flow-node.t2::before { background: linear-gradient(90deg, var(--color-primary-dark), var(--color-primary)); }
  .flow-node.t3::before { background: linear-gradient(90deg, var(--color-secondary), var(--color-secondary-light)); }

  .flow-tier {
    font-family: var(--font-family-sans);
    font-size: 0.66rem;
    font-weight: 700;
    color: var(--color-primary);
    background: var(--color-primary-surface);
    padding: 0.25rem 0.65rem;
    border-radius: 6px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    display: inline-block;
    margin-bottom: 0.85rem;
  }

  .flow-name {
    font-family: var(--font-family-display);
    font-weight: 800;
    font-size: 1.4rem;
    color: var(--color-text-heading);
    margin: 0 0 0.5rem 0;
  }

  .flow-desc {
    font-family: var(--font-family-sans);
    color: var(--color-text-muted);
    font-size: 0.92rem;
    line-height: 1.55;
    margin: 0 0 1rem 0;
  }

  .flow-meta {
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 0.72rem;
    color: var(--color-text-muted);
  }

  .flow-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    flex: 0 0 2.5rem;
  }

  .flow-arrow .material-symbols-outlined { font-size: 28px; }

  @media (max-width: 820px) {
    .flow { flex-direction: column; }
    .flow-arrow { flex: 0 0 2.5rem; }
    .flow-arrow .material-symbols-outlined { transform: rotate(90deg); }
  }

  .flow-rule {
    margin-top: 1.5rem;
    background: var(--color-primary-surface);
    border-left: 4px solid var(--color-primary);
    border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
    padding: 1rem 1.35rem;
    font-family: var(--font-family-sans);
    font-size: 0.98rem;
    color: var(--color-primary-dark);
    line-height: 1.55;
  }

  .flow-rule strong { color: #312e81; }

  /* ===== NAMING CARDS ===== */
  .name-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 820px) {
    .name-grid { grid-template-columns: 1fr; }
  }

  .name-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
  }

  .name-tag {
    display: inline-block;
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-primary-dark);
    background: var(--color-primary-surface);
    padding: 0.3rem 0.7rem;
    border-radius: 6px;
    margin-bottom: 1rem;
  }

  .name-scope {
    font-family: var(--font-family-display);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-text-heading);
    margin: 0 0 0.4rem 0;
  }

  .name-desc {
    font-family: var(--font-family-sans);
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.55;
    margin: 0;
  }

  .name-desc code {
    background: var(--color-surface-secondary);
    padding: 0.1rem 0.35rem;
    border-radius: var(--radius-sm);
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 0.82em;
    color: var(--color-primary-dark);
  }

  /* ===== PIPELINE ===== */
  .pipe-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  @media (max-width: 900px) {
    .pipe-grid { grid-template-columns: 1fr; }
  }

  .pipe {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .pipe-node {
    flex: 1;
    min-width: 90px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1rem 0.75rem;
    text-align: center;
    box-shadow: var(--shadow-sm);
  }

  .pipe-node .material-symbols-outlined {
    font-size: 26px;
    color: var(--color-primary);
    margin-bottom: 0.4rem;
  }

  .pipe-node-label {
    font-family: var(--font-family-sans);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-heading);
    line-height: 1.3;
  }

  .pipe-arrow { color: var(--color-primary); flex: 0 0 auto; }
  .pipe-arrow .material-symbols-outlined { font-size: 22px; }

  .pipe-line {
    font-family: var(--font-family-sans);
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .pipe-line strong { color: var(--color-text-heading); font-weight: 600; }

  .intro-code {
    background: #1e293b;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .intro-code-header {
    background: #334155;
    padding: 0.7rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .intro-code-dot { width: 11px; height: 11px; border-radius: var(--radius-pill); }
  .intro-code-dot.d1 { background: #64748b; }
  .intro-code-dot.d2 { background: #94a3b8; }
  .intro-code-dot.d3 { background: #cbd5e1; }

  .intro-code-lang {
    margin-left: auto;
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 0.72rem;
    color: #cbd5e1;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .intro-code pre {
    margin: 0;
    padding: 1.25rem;
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 0.82rem;
    line-height: 1.75;
    color: #e2e8f0;
    overflow-x: auto;
  }

  .intro-code .c-cm { color: #94a3b8; font-style: italic; }
  .intro-code .c-sel { color: #fbbf24; }
  .intro-code .c-prop { color: #7dd3fc; }
  .intro-code .c-val { color: #a5f3fc; }
  .intro-code .c-kw { color: #c084fc; }
  .intro-code .c-p { color: #94a3b8; }

  /* ===== BOOK MAP ===== */
  .book-group { margin-bottom: 2rem; }

  .book-group-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .book-group-tier {
    font-family: var(--font-family-sans);
    font-size: 0.66rem;
    font-weight: 700;
    color: var(--color-primary);
    background: var(--color-primary-surface);
    padding: 0.25rem 0.6rem;
