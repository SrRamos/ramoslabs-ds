    margin-bottom: 3rem;
    background: radial-gradient(120% 140% at 100% 0%, #4f46e5 0%, #4338ca 42%, #312e81 100%);
    box-shadow: 0 16px 32px -8px rgba(79,70,229,0.12), 0 4px 8px -2px rgba(79,70,229,0.06);
  }

  .fe-hero-eyebrow {
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: #c7d2fe;
    margin: 0 0 1rem;
  }

  .fe-hero h1 {
    font-family: 'Red Hat Display', system-ui, sans-serif;
    color: #ffffff;
    font-size: clamp(2rem, 4vw + 1rem, 3.1rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 0 1.25rem;
    max-width: 22ch;
  }

  .fe-hero p {
    color: #e0e7ff;
    font-size: 1.0625rem;
    line-height: 1.6;
    max-width: 44rem;
    margin: 0;
  }

  .fe-hero p strong { color: #ffffff; font-weight: 700; }

  /* ===== PART BANNER ===== */
  .fe-part {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    margin: 3.5rem 0 0.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #4f46e5;
  }

  .fe-part-kicker {
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #4338ca;
    background: #e0e7ff;
    border-radius: 6px;
    padding: 0.2rem 0.6rem;
  }

  .fe-part-title {
    font-family: 'Red Hat Display', system-ui, sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    color: #0f172a;
    letter-spacing: -0.02em;
  }

  /* ===== SECTIONS ===== */
  .fe-section {
    margin-top: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #e6e8eb;
  }

  .fe-section:last-of-type { border-bottom: none; }

  .fe-section-header {
    display: flex;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .fe-section-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    background: #4f46e5;
    color: white;
    border-radius: 50%;
    font-size: 0.875rem;
    font-weight: 700;
    margin-right: 0.75rem;
    flex-shrink: 0;
  }

  .fe-section-title {
    font-family: 'Red Hat Display', system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #0f172a;
  }

  .fe-text {
    font-family: 'Rubik', system-ui, sans-serif;
    color: #475569;
    font-size: 0.9375rem;
    line-height: 1.7;
    max-width: 48rem;
  }

  .fe-text + .fe-text { margin-top: 1rem; }

  .fe-text strong { color: #0f172a; font-weight: 600; }

  .fe-text code, .fe-inline-code {
    background: #f1f5f9;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.875em;
    color: #4338ca;
    font-family: 'SF Mono', 'Monaco', monospace;
  }

  /* ===== CALLOUT ===== */
  .fe-callout {
    display: flex;
    gap: 0.75rem;
    background: #eef2ff;
    border: 1px solid #c7d2fe;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    margin: 1.25rem 0;
    max-width: 48rem;
  }

  .fe-callout .fe-material {
    color: #4338ca;
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .fe-callout-text {
    font-family: 'Rubik', system-ui, sans-serif;
    font-size: 0.875rem;
    line-height: 1.6;
    color: #3730a3;
  }

  .fe-callout-text strong { color: #312e81; font-weight: 700; }

  .fe-callout-text code {
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 0.85em;
    background: rgba(79,70,229,0.1);
    padding: 1px 5px;
    border-radius: 4px;
    color: #3730a3;
  }

  /* ===== LAB / DEMO ===== */
  .fe-lab {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1rem;
    margin: 1.25rem 0;
  }

  .fe-demo {
    background: white;
    border: 1px solid #e6e8eb;
    border-radius: 12px;
    padding: 1.5rem;
  }

  .fe-demo-label {
    font-weight: 700;
    font-size: 0.6875rem;
    text-transform: uppercase;
    color: #475569;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
  }

  /* ===== FIELD PRIMITIVES ===== */
  .fe-field { margin-bottom: 1.25rem; }
  .fe-field:last-child { margin-bottom: 0; }

  .fe-label {
    display: block;
    font-family: 'Rubik', system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: #0f172a;
    margin-bottom: 0.25rem;
  }

  .fe-label .fe-req { color: #dc2626; margin-left: 0.15rem; }
  .fe-label .fe-opt {
    color: #64748b;
    font-weight: 400;
    font-size: 0.8125rem;
    margin-left: 0.35rem;
  }

  .fe-help {
    font-family: 'Rubik', system-ui, sans-serif;
    font-size: 0.8125rem;
    color: #64748b;
    margin-top: 0.3rem;
    line-height: 1.5;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .fe-input {
    width: 100%;
    box-sizing: border-box;
    background: white;
    border: 1px solid #64748b;
    border-radius: 6px;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    color: #0f172a;
    font-family: 'Rubik', sans-serif;
    caret-color: var(--color-primary);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .fe-input::placeholder { color: #64748b; }

  .fe-input:focus-visible {
    outline: none;
    border-color: #4f46e5;
    box-shadow: 0 0 0 2px #ffffff, 0 0 0 4px #4f46e5;
  }

  .fe-input.error {
    border-color: #ef4444;
  }

  .fe-input.error:focus-visible {
    box-shadow: 0 0 0 2px #ffffff, 0 0 0 4px #dc2626;
  }

  .fe-input.success { border-color: #059669; }

  select.fe-input { appearance: auto; cursor: pointer; }

  .fe-error {
    display: flex;
    align-items: flex-start;
    gap: 0.35rem;
    font-family: 'Rubik', system-ui, sans-serif;
    font-size: 0.8125rem;
    color: #991b1b;
    margin-top: 0.35rem;
    line-height: 1.45;
  }

  .fe-error .fe-material { font-size: 1rem; color: #dc2626; flex-shrink: 0; margin-top: 0.05rem; }

  .fe-success-text {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: 'Rubik', system-ui, sans-serif;
    font-size: 0.8125rem;
    color: #166534;
    margin-top: 0.35rem;
  }

  .fe-success-text .fe-material { font-size: 1rem; color: #059669; }

  /* ===== ANATOMY ===== */
  .fe-anatomy {
    position: relative;
    background: #f8fafc;
    border: 1px solid #e6e8eb;
    border-radius: 12px;
    padding: 1.5rem;
    margin: 1.25rem 0;
  }

  .fe-anatomy-part {
    display: grid;
    grid-template-columns: 8.5rem 1fr;
    gap: 0.75rem;
    align-items: center;
    padding: 0.5rem 0;
  }

  @media (max-width: 560px) {
    .fe-anatomy-part { grid-template-columns: 1fr; gap: 0.25rem; }
  }

  .fe-anatomy-tag {
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    color: #4338ca;
    background: #e0e7ff;
    border-radius: 6px;
    padding: 0.2rem 0.5rem;
    text-align: center;
    align-self: start;
  }

  /* ===== TABLE ===== */
  .fe-table-scroll {
    overflow-x: auto;
    margin: 1.25rem 0;
    border: 1px solid #e6e8eb;
    border-radius: 12px;
  }

  .fe-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'Rubik', system-ui, sans-serif;
    font-size: 0.8125rem;
    min-width: 680px;
  }

  .fe-table th {
    text-align: left;
    padding: 0.75rem 1rem;
    background: #f8fafc;
    color: #0f172a;
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-bottom: 1px solid #e6e8eb;
    white-space: nowrap;
  }

  .fe-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #f1f5f9;
    color: #475569;
    vertical-align: top;
  }

  .fe-table tr:last-child td { border-bottom: none; }

  .fe-table code {
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 0.9em;
    color: #4338ca;
    background: #eef2ff;
    padding: 1px 5px;
    border-radius: 4px;
    white-space: nowrap;
  }

  .fe-table .fe-kbd {
    font-weight: 600;
    color: #0f172a;
    white-space: nowrap;
  }

  .fe-yes { color: #166534; font-weight: 700; }
  .fe-no { color: #991b1b; font-weight: 700; }
  .fe-yes .fe-material, .fe-no .fe-material { font-size: 0.95rem; vertical-align: -0.15rem; }

  /* ===== TIMELINE (validation) ===== */
  .fe-timeline {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 0.75rem;
    margin: 1.25rem 0;
  }

  .fe-tl-step {
    background: white;
    border: 1px solid #e6e8eb;
    border-radius: 10px;
    padding: 1rem;
  }

  .fe-tl-when {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #4338ca;
    background: #eef2ff;
    border-radius: 6px;
    padding: 0.15rem 0.55rem;
    margin-bottom: 0.6rem;
  }

  .fe-tl-title {
    font-family: 'Rubik', system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: #0f172a;
    margin-bottom: 0.3rem;
  }

  .fe-tl-body {
    font-family: 'Rubik', system-ui, sans-serif;
    font-size: 0.8125rem;
    color: #64748b;
    line-height: 1.5;
  }

  /* ===== NATIVE ACCENT LAB ===== */
  .fe-accent-lab {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
    background: #f8fafc;
    border: 1px solid #e6e8eb;
    border-radius: 12px;
    padding: 1.5rem;
    margin: 1.25rem 0;
  }

  .fe-accent-lab input[type="checkbox"],
  .fe-accent-lab input[type="radio"],
  .fe-accent-lab input[type="range"],
  .fe-accent-lab progress {
    accent-color: var(--color-primary);
  }

  .fe-accent-lab input[type="checkbox"],
  .fe-accent-lab input[type="radio"] {
    width: 1.5rem;
    height: 1.5rem;
    margin: 0;
  }

  .fe-accent-lab input[type="range"] { width: 100%; }
  .fe-accent-lab progress { width: 100%; height: 0.75rem; }

  .fe-accent-group {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .fe-accent-cap {
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #475569;
    margin-bottom: 0.15rem;
  }

  .fe-accent-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: 'Rubik', system-ui, sans-serif;
    font-size: 0.9375rem;
    color: #0f172a;
  }

  /* ===== CODE BLOCK ===== */
  .fe-code {
    background: #0f172a;
    border-radius: 10px;
    padding: 1.1rem 1.3rem;
    margin: 1.25rem 0;
    max-width: 48rem;
    overflow-x: auto;
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 0.8125rem;
    line-height: 1.75;
    color: #e2e8f0;
  }

  .fe-code .fe-c-com { color: #94a3b8; }
  .fe-code .fe-c-prop { color: #a5b4fc; }
  .fe-code .fe-c-sel { color: #c4b5fd; }

  /* ===== RECOMMENDED / AVOID DEMO ===== */
  .fe-demo.avoid {
    border-style: dashed;
    border-color: #cbd5e1;
    background: #fbfcfd;
  }

  .fe-demo-label.rec { color: #166534; }
  .fe-demo-label.avoid { color: #991b1b; }

  /* ===== RULES (Rule / Why) ===== */
  .fe-rules {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 1.25rem 0;
    max-width: 48rem;
  }

  .fe-rule {
    background: white;
    border: 1px solid #e6e8eb;
    border-left: 3px solid #4f46e5;
    border-radius: 10px;
    padding: 0.9rem 1.125rem;
  }

  .fe-rule-line {
    font-family: 'Rubik', system-ui, sans-serif;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: #0f172a;
    margin: 0;
  }

  .fe-rule-why {
    font-family: 'Rubik', system-ui, sans-serif;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: #64748b;
    margin: 0.35rem 0 0;
  }

  .fe-tag {
    display: inline-block;
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
    margin-right: 0.5rem;
    vertical-align: 0.08em;
  }

  .fe-tag.rule { color: #4338ca; background: #e0e7ff; }
  .fe-tag.why { color: #475569; background: #f1f5f9; }

  .fe-rule code {
    background: rgba(15, 23, 42, 0.06);
    padding: 1px 5px;
    border-radius: 4px;
    font-size: 0.8125em;
    font-family: 'SF Mono', 'Monaco', monospace;
    color: #334155;
  }

  /* ===== LADDER ===== */
  .fe-ladder {
    counter-reset: fe-step;
    margin: 1.25rem 0;
    max-width: 48rem;
  }

  .fe-ladder-step {
    display: flex;
    gap: 0.875rem;
    padding: 0.875rem 0;
    border-bottom: 1px dashed #e2e8f0;
  }

  .fe-ladder-step:last-child { border-bottom: none; }

  .fe-ladder-step::before {
    counter-increment: fe-step;
    content: counter(fe-step);
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    background: #eef2ff;
    color: #4338ca;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'SF Mono', monospace;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .fe-ladder-text {
    font-family: 'Rubik', system-ui, sans-serif;
    font-size: 0.875rem;
    line-height: 1.5;
    color: #334155;
  }

  .fe-ladder-text strong { color: #0f172a; }

  /* ===== CROSS-LINK CHIP ===== */
  .fe-xlink {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Rubik', system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #4338ca;
    background: #eef2ff;
    border: 1px solid #c7d2fe;
    border-radius: 6px;
    padding: 0.4rem 0.9rem;
    margin: 1rem 0.5rem 0 0;
    text-decoration: none;
  }

  .fe-xlink:hover { background: #e0e7ff; }
  .fe-xlink .fe-material { font-size: 1rem; }

  /* ===== CATALOG CARDS ===== */
  .fe-family {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin: 2rem 0 0.5rem;
  }

  .fe-family .fe-material {
    color: #4f46e5;
    font-size: 1.35rem;
  }

  .fe-family-title {
    font-family: 'Red Hat Display', system-ui, sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: #0f172a;
  }

  .fe-catalog {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1rem;
    margin: 1rem 0 1.5rem;
  }

  .fe-cat {
    background: white;
    border: 1px solid #e6e8eb;
    border-radius: 12px;
    padding: 1.15rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .fe-cat-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .fe-cat-name {
    font-family: 'Rubik', system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 700;
    color: #0f172a;
  }

  .fe-verdict {
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 6px;
    padding: 0.15rem 0.55rem;
    white-space: nowrap;
  }

  .fe-verdict.native { color: #166534; background: #f0fdf4; border: 1px solid #bbf7d0; }
  .fe-verdict.custom { color: #4338ca; background: #eef2ff; border: 1px solid #c7d2fe; }
  .fe-verdict.hybrid { color: #475569; background: #f1f5f9; border: 1px solid #e2e8f0; }

  .fe-cat-el {
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 0.8125rem;
    color: #4338ca;
    margin: 0;
  }

  .fe-cat-attrs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .fe-cat-attrs code {
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 0.6875rem;
    color: #4338ca;
    background: #eef2ff;
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
  }

  .fe-cat-notes {
    list-style: none;
    margin: 0.15rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .fe-cat-notes li {
    display: flex;
    align-items: flex-start;
    gap: 0.45rem;
    font-family: 'Rubik', system-ui, sans-serif;
    font-size: 0.8125rem;
    line-height: 1.45;
    color: #475569;
  }

  .fe-cat-notes li .fe-material {
    font-size: 0.95rem;
    color: #64748b;
    flex-shrink: 0;
    margin-top: 0.05rem;
  }

  .fe-cat-notes li strong { color: #0f172a; font-weight: 600; }

  /* ===== IN-CARD LIVE DEMO ===== */
  .fe-cat-demo {
    background: #f8fafc;
    border: 1px solid #e6e8eb;
    border-radius: 8px;
    padding: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .fe-cat-demo .fe-input { border-radius: 6px; padding: 0.6rem 0.75rem; }

  .fe-cat-field { display: flex; flex-direction: column; gap: 0.3rem; }

  .fe-cat-lbl {
    font-family: 'Rubik', system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #0f172a;
  }

  .fe-cat-demo legend.fe-cat-lbl { margin-bottom: 0.4rem; padding: 0; }

  .fe-cat-demo input[type="checkbox"],
  .fe-cat-demo input[type="radio"],
  .fe-cat-demo input[type="range"] {
    accent-color: var(--color-primary, #4f46e5);
  }

  .fe-cat-demo input[type="checkbox"]:not(.fe-switch),
  .fe-cat-demo input[type="radio"] {
    width: 1.25rem;
    height: 1.25rem;
    margin: 0;
    flex-shrink: 0;
  }

  .fe-cat-demo input[type="range"] { width: 100%; }

  .fe-cat-choice {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: 'Rubik', system-ui, sans-serif;
    font-size: 0.875rem;
    color: #0f172a;
    min-height: 1.75rem;
    cursor: pointer;
  }

  .fe-cat-group {
    border: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .fe-cat-hex {
    width: 7rem;
    font-family: 'SF Mono', 'Monaco', monospace;
    text-transform: uppercase;
  }

  /* ===== LIVE SWITCH (APG role="switch") ===== */
  .fe-switch {
    appearance: none;
    -webkit-appearance: none;
    width: 2.75rem;
    height: 1.5rem;
    border-radius: 9999px;
    background: #94a3b8;
    position: relative;
    cursor: pointer;
    flex-shrink: 0;
    margin: 0;
    transition: background 0.15s ease;
  }

  .fe-switch:checked { background: var(--color-primary, #4f46e5); }

  .fe-switch::before {
    content: "";
    position: absolute;
    top: 0.2rem;
    left: 0.2rem;
    width: 1.1rem;
    height: 1.1rem;
    border-radius: 9999px;
    background: white;
