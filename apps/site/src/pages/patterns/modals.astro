<script is:inline>
  // Progressive enhancement: open each demo dialog with the native showModal()
  // (top layer, focus trap, Escape-to-close, ::backdrop). The dialogs close via their
  // <form method="dialog"> buttons, so nothing here submits or reloads the page.
  for (const trigger of document.querySelectorAll('[data-open-dialog]')) {
    trigger.addEventListener('click', () => {
      const dialog = document.getElementById(trigger.getAttribute('data-open-dialog'));
      if (dialog && typeof dialog.showModal === 'function') dialog.showModal();
    });
  }
</script>
