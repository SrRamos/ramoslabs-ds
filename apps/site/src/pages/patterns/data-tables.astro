                <tr><th scope="row" class="stick">Jordan Ellis</th><td><span class="dt-badge paid">Paid</span></td><td>Portland</td><td>VIP</td><td class="num">420,000</td></tr>
                <tr><th scope="row" class="stick">Riley Chen</th><td><span class="dt-badge pending">Pending</span></td><td>Cali</td><td>General</td><td class="num">180,000</td></tr>
