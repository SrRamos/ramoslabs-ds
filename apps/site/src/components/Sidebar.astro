---
import Icon from './Icon.astro'
import { rootPages, agentsPages, foundationsPages, patternsPages } from '../data/pages'

// Left navigation. Grouped Foundations / Patterns, current-page highlight from the URL.
const current = Astro.url.pathname
const isActive = (path: string) => current === path || current === path.replace(/\/$/, '')

const groups = [
  { label: 'For Agents', tier: 'MCP', pages: agentsPages, agentic: true },
  { label: 'Foundations', tier: 'Tier 1', pages: foundationsPages, agentic: false },
  { label: 'Patterns', tier: 'Tier 2', pages: patternsPages, agentic: false },
]
---
<nav class="rl-nav" aria-label="Documentation">
  <a class="rl-nav__brand" href="/">
    <span class="rl-nav__brand-mark" aria-hidden="true"></span>
    <span class="rl-nav__brand-text">
      RamosLabs
      <small>Design System</small>
    </span>
  </a>

  <ul class="rl-nav__list rl-nav__list--root">
    {rootPages.map((page) => (
      <li>
        <a class:list={['rl-nav__link', { 'is-active': isActive(page.path) }]} href={page.path} aria-current={isActive(page.path) ? 'page' : undefined}>
          <Icon name={page.icon} />
          <span>{page.title}</span>
        </a>
      </li>
    ))}
  </ul>

  {groups.map((group) => (
    <div class="rl-nav__group">
      <p class="rl-nav__group-head">
        <span class:list={['rl-nav__group-tier', { 'is-agentic': group.agentic }]}>{group.tier}</span>
        {group.label}
      </p>
      <ul class="rl-nav__list">
        {group.pages.map((page) => (
          <li>
            <a class:list={['rl-nav__link', { 'is-active': isActive(page.path) }]} href={page.path} aria-current={isActive(page.path) ? 'page' : undefined}>
              <Icon name={page.icon} />
              <span>{page.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  ))}
</nav>

<style>
  .rl-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-5, 1.25rem);
    padding: var(--space-6, 1.5rem) var(--space-4, 1rem);
    font-family: var(--font-family-sans, 'Rubik', system-ui, sans-serif);
  }

  .rl-nav__brand {
    display: flex;
    align-items: center;
    gap: var(--space-3, 0.75rem);
    text-decoration: none;
    padding: 0 var(--space-2, 0.5rem);
    margin-bottom: var(--space-2, 0.5rem);
  }
  .rl-nav__brand-mark {
    width: 28px;
    height: 28px;
    border-radius: var(--radius-md, 8px);
    background: linear-gradient(135deg, var(--color-primary, #4f46e5), var(--color-secondary, #7c3aed));
    flex-shrink: 0;
    box-shadow: var(--shadow-sm);
  }
  .rl-nav__brand-text {
    font-family: var(--font-family-display, 'Red Hat Display', system-ui, sans-serif);
    font-weight: 800;
    font-size: 1.05rem;
    line-height: 1.05;
    color: var(--color-text-heading, #0f172a);
    display: flex;
    flex-direction: column;
  }
  .rl-nav__brand-text small {
    font-family: var(--font-family-sans, 'Rubik', system-ui, sans-serif);
    font-weight: 500;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted, #64748b);
    margin-top: 2px;
  }

  .rl-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .rl-nav__group-head {
    display: flex;
    align-items: center;
    gap: var(--space-2, 0.5rem);
    margin: 0 0 var(--space-2, 0.5rem);
    padding: 0 var(--space-2, 0.5rem);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted, #64748b);
  }
  .rl-nav__group-tier {
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--color-primary, #4f46e5);
    background: var(--color-primary-surface, #eef2ff);
    padding: 0.15rem 0.45rem;
    border-radius: var(--radius-sm, 4px);
    letter-spacing: 0.04em;
  }
  /* Decorative violet marks the agent-facing group apart from the tiered doctrine. */
  .rl-nav__group-tier.is-agentic {
    color: var(--color-secondary, #7c3aed);
    background: var(--color-secondary-surface, #f5f3ff);
  }

  .rl-nav__link {
    display: flex;
    align-items: center;
    gap: var(--space-3, 0.75rem);
    padding: var(--space-2, 0.5rem) var(--space-3, 0.75rem);
    border-radius: var(--radius-md, 8px);
    text-decoration: none;
    color: var(--color-text-secondary, #334155);
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.2;
    transition: background 120ms ease, color 120ms ease;
  }
  .rl-nav__link .material-symbols-outlined {
    font-size: 20px;
    color: var(--color-text-muted, #64748b);
  }
  @media (hover: hover) {
    .rl-nav__link:hover {
      background: var(--color-surface-hover, #f1f5f9);
      color: var(--color-text-heading, #0f172a);
    }
  }
  .rl-nav__link.is-active {
    background: var(--color-primary-surface, #eef2ff);
    color: var(--color-primary-dark, #3730a3);
    font-weight: 600;
  }
  .rl-nav__link.is-active .material-symbols-outlined {
    color: var(--color-primary, #4f46e5);
  }
</style>
