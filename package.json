{
  "name": "ramoslabs-ds",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "description": "RamosLabs Design System monorepo. Tokens are the single source of truth.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22",
    "bun": ">=1.3"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "storybook": "bun run --filter storybook storybook",
    "build-storybook": "bun run --filter storybook build-storybook"
  },
  "devDependencies": {
    "turbo": "^2.10.0",
    "typescript": "^5.9.0"
  }
}
